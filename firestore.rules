rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Primitives ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      // For this app, let's assume the store owner is the one who set it up.
      // In a real multi-tenant app, we'd check a roles collection.
      // Here we'll check if the user's UID is in an 'admins' collection.
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- Entity Validations ---

    function isValidStore(data) {
      return data.name is string && data.name.size() <= 100
          && data.shopifyDomain is string && data.shopifyDomain.size() <= 100
          && (!data.theme.hasAny(['light', 'dark']) || data.theme in ['light', 'dark']);
    }

    function isValidProduct(data) {
      return data.shopifyId is string && data.title is string && data.price is number;
    }

    function isValidOrder(data) {
      return data.shopifyId is string && data.orderNumber is string && data.customerEmail is string;
    }

    function isValidChat(data) {
      return data.messages is list && data.status in ['open', 'closed'];
    }

    // --- Match Blocks ---

    // Admins collection
    match /admins/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
    }

    match /stores/{storeId} {
      allow read: if true; // Public store info
      allow write: if isAdmin();
      
      match /products/{productId} {
        allow read: if true;
        allow write: if isAdmin();
      }

      match /orders/{orderId} {
        // Users can query their own orders by email. 
        // Note: For 'list' operations, the client must filter by email.
        allow read: if isAdmin() || (isSignedIn() && resource.data.customerEmail == request.auth.token.email);
        allow write: if isAdmin();
      }

      match /chats/{chatId} {
        // Anyone can create a chat, but then only the session owner or admin can read/write it.
        // We might use an anonymous ID or email for guest users.
        allow create: if true; 
        allow get: if isAdmin() || (resource.data.customerId == request.auth.uid) || (resource.data.customerEmail == request.auth.token.email);
        allow list: if isAdmin();
        allow update: if (isAdmin() || resource.data.customerId == request.auth.uid) && isValidChat(request.resource.data);
      }

      match /analytics/{snapshotId} {
        allow read, write: if isAdmin();
      }
    }
  }
}
